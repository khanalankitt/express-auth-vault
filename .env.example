NODE_ENV=development
PORT=5000

# Standard PostgreSQL URL — works with local Postgres, Supabase, Neon, RDS, etc.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_vault"

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m

BCRYPT_COST=12

# Base URL used to build password reset links in emails.
APP_URL=http://localhost:5000

# Comma-separated list of allowed origins for cookie-based auth.
# Use "*" to allow any origin — credentials (cookies) are disabled in that mode.
CORS_ORIGIN=http://localhost:3000

# Optional SMTP — if unset, password reset links are logged to the console
# (handy for local development).
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@auth-vault.local
